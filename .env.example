# 0G Memory Hub - Environment Configuration

# 0G Storage Configuration
OG_STORAGE_RPC=https://testnet-rpc.0g.ai
OG_STORAGE_INDEXER=https://testnet-indexer.0g.ai

# 0G Chain Configuration
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_TESTNET_CHAIN_ID=16602
# Optional: set these before mainnet deployment / verification
# OG_MAINNET_RPC=https://evmrpc.0g.ai
# OG_MAINNET_CHAIN_ID=16661
# OG_TESTNET_EXPLORER_URL=https://chainscan-galileo.0g.ai
# OG_MAINNET_EXPLORER_URL=https://chainscan.0g.ai

# Private Key (for signing transactions)
# WARNING: Never commit this file with real private keys!
PRIVATE_KEY=

# Smart Contract Address
CONTRACT_ADDRESS=

# Logging Level
RUST_LOG=info

# Optional: Custom RPC endpoints
# CUSTOM_STORAGE_RPC=http://localhost:8545
# CUSTOM_CHAIN_RPC=http://localhost:8546
