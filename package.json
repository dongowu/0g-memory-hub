{
  "name": "0g-memory-hub",
  "version": "0.1.0",
  "description": "AI Agent Eternal Memory System on 0G",
  "main": "index.js",
  "scripts": {
    "wallet:new": "node scripts/generate_testnet_wallet.js",
    "wallet:new:save": "node scripts/generate_testnet_wallet.js --save",
    "preflight:testnet": "node scripts/check_testnet_env.js",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test test/MemoryAnchor.js",
    "deploy": "hardhat run scripts/deploy.js --network 0g-testnet",
    "deploy:proof": "RUN_ANCHOR_PROOF=1 hardhat run scripts/deploy.js --network 0g-testnet",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network 0g-mainnet",
    "deploy:proof:mainnet": "RUN_ANCHOR_PROOF=1 hardhat run scripts/deploy.js --network 0g-mainnet",
    "deploy:legacy": "CONTRACT_NAME=MemoryChain hardhat run scripts/deploy.js --network 0g-testnet",
    "evidence:testnet": "node scripts/render_deployment_evidence.js deployments/0g-testnet/MemoryAnchor.latest.json",
    "verify": "hardhat verify",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "gas-report": "REPORT_GAS=true hardhat test"
  },
  "keywords": [
    "0G",
    "AI",
    "Agent",
    "Memory",
    "Blockchain",
    "Storage",
    "Smart Contract"
  ],
  "author": "dongowu",
  "license": "MIT",
  "engines": {
    "node": ">=20 <25"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "ethers": "^6.9.0"
  }
}
